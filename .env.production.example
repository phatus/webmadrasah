# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env (DO NOT COMMIT .env!)
# Fill in the values from your hosting provider

# --------------------------------------------
# Database
# --------------------------------------------
# For Vercel/Railway/Other: Use PostgreSQL
# Get from your database provider (Neon, Supabase, Railway)
# Example: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://..."

# For local testing only: file:./dev.db (SQLite)
# Note: SQLite does NOT work on Vercel production

# --------------------------------------------
# Authentication
# --------------------------------------------
# Generate strong random secret (64+ chars):
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="your-64-character-secret-here-change-in-production"

# --------------------------------------------
# Cloudinary (Image Uploads)
# --------------------------------------------
# Get from: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# --------------------------------------------
# Application
# --------------------------------------------
NODE_ENV="production"

# --------------------------------------------
# Optional: Monitoring (if configured)
# --------------------------------------------
# SENTRY_DSN="https://your-sentry-dsn"
# LOG_LEVEL="info"
