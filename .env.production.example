# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# IMPORTANT:
# 1. Copy this file to .env (DO NOT COMMIT .env!)
# 2. Fill in the actual values for your production deployment
# 3. For Vercel/Railway: Add these as Environment Variables in dashboard
#
# How to use:
#   cp .env.production.example .env
#   Edit .env with your actual values

# --------------------------------------------
# DATABASE (REQUIRED)
# --------------------------------------------
# For production: PostgreSQL (highly recommended)
# Get FREE PostgreSQL from:
#   - Neon.tech (10GB free) - https://neon.tech
#   - Supabase.com (500MB free) - https://supabase.com
#   - Railway.app ($5 free credit) - https://railway.app
#
# Local development uses SQLite (file:./dev.db)
#
# PostgreSQL connection string example:
# DATABASE_URL="postgresql://username:password@host:port/database"
#
# SQLite (local only - DO NOT use in production):
# DATABASE_URL="file:./dev.db"
#
DATABASE_URL="postgresql://username:password@host:port/database"

# --------------------------------------------
# AUTHENTICATION (REQUIRED)
# --------------------------------------------
# Generate a STRONG random secret (minimum 64 hex characters):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# IMPORTANT: This MUST be different from development!
# Development AUTH_SECRET: 4ad087d63f47e9923fef02c4da68646d32e3827f792ffebd06d608d6c8b8b74c
# DO NOT use the same secret in production!
#
AUTH_SECRET="generate-your-own-64-char-secret-here"

# --------------------------------------------
# CLOUDINARY (Image Uploads - REQUIRED)
# --------------------------------------------
# Sign up at: https://cloudinary.com
# Create upload preset named "webmadrasah_preset" (unsigned)
#
# Get credentials from Cloudinary Dashboard:
#   - Cloud Name: dgx0p6axm (from development)
#   - API Key: Get from Cloudinary Console
#   - API Secret: Get from Cloudinary Console
#
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="dgx0p6axm"
CLOUDINARY_API_KEY="your-api-key-here"
CLOUDINARY_API_SECRET="your-api-secret-here"

# --------------------------------------------
# APPLICATION (REQUIRED)
# --------------------------------------------
NODE_ENV="production"

# --------------------------------------------
# OPTIONAL: Monitoring & Analytics
# --------------------------------------------
# Error tracking (Sentry)
# SENTRY_DSN="https://your-sentry-dsn.ingest.sentry.io/project-id"

# Log level (debug, info, warn, error)
# LOG_LEVEL="info"

# --------------------------------------------
# QUICK SETUP CHECKLIST:
# --------------------------------------------
# [ ] 1. Generate AUTH_SECRET (run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# [ ] 2. Get PostgreSQL from Neon/Supabase/Railway
# [ ] 3. Update DATABASE_URL with PostgreSQL connection
# [ ] 4. Get Cloudinary API Key & Secret
# [ ] 5. Create upload preset "webmadrasah_preset" in Cloudinary
# [ ] 6. Add all variables to Vercel/Platform environment
# [ ] 7. Run: npm run setup:prod (to create admin user)
# [ ] 8. Login with admin / WebMadrasah@2024 and change password!
#
# See DEPLOYMENT.md for full deployment guide
