# Database Settings (Local PostgreSQL or Supabase)
# Opsi A: PostgreSQL Lokal Server (Direkomendasikan setelah migrasi dari Supabase)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/webmadrasah?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/webmadrasah?schema=public"

# Opsi B: Supabase (Cloud PostgreSQL) - Hubungkan lewat connection pooling (?pgbouncer=true)
# DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Authentication
# IMPORTANT: Generate a strong random secret for production!
# Command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="your-secret-key-here-replace-with-actual-secret"

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="dgx0p6axm"
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
